{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "react-devops-cloud-dashboard-TaskDefinition-Prod",
    "containerDefinitions": [
        {
            "name": "react-devops-cloud-dashboard",
            "image": "002574138182.dkr.ecr.eu-central-1.amazonaws.com:#APP_VERSION#",
            "portMappings": [
                {
                    "name": "ngnix-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": ""
}